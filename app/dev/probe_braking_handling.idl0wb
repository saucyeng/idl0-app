{
  "workbook_id": "b9a1c0de-0000-4000-8000-000000000042",
  "name": "Braking & Handling",
  "workbook_version": 1,
  "created_at_ms": 1767225600000,
  "updated_at_ms": 1767225600000,
  "math_channels": [
    {
      "name": "Longitudinal G",
      "expression": "butter(2, 5.0, \"low\", [IMU0_AccelX])",
      "quantity": "Acceleration",
      "units": "g",
      "sample_rate_hz": 0.0,
      "decimal_places": 2,
      "color": "#FFFF5252"
    },
    {
      "name": "Lateral G",
      "expression": "butter(2, 5.0, \"low\", [IMU0_AccelY])",
      "quantity": "Acceleration",
      "units": "g",
      "sample_rate_hz": 0.0,
      "decimal_places": 2,
      "color": "#FF40C4FF"
    },
    {
      "name": "Braking event",
      "expression": "if([IMU0_AccelX] < -0.2, 1, 0)",
      "quantity": "State",
      "units": "",
      "sample_rate_hz": 0.0,
      "decimal_places": 0,
      "color": "#FFFFD740"
    },
    {
      "name": "Fork velocity",
      "expression": "integrate([IMU1_AccelZ])",
      "quantity": "Velocity",
      "units": "m/s",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FFB388FF"
    },
    {
      "name": "Speed m/s",
      "expression": "[GPS_SpeedKmh] / 3.6",
      "quantity": "Velocity",
      "units": "m/s",
      "sample_rate_hz": 0.0,
      "decimal_places": 2,
      "color": "#FF69F0AE"
    }
  ],
