{
  "workbook_id": "central-imu-analysis-v1",
  "name": "Central IMU + GPS + HR",
  "workbook_version": 1,
  "created_at_ms": 1781654400000,
  "updated_at_ms": 1781654400000,
  "math_channels": [
    {
      "name": "Longitudinal accel",
      "expression": "vx(rotate_axis(vec(declip([IMU0_AccelX]), declip([IMU0_AccelY]), declip([IMU0_AccelZ])), 0, 1, 0, deg2rad(30)))",
      "quantity": "Acceleration",
      "units": "g",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FF00BCD4"
    },
    {
      "name": "Lateral accel",
      "expression": "vy(rotate_axis(vec(declip([IMU0_AccelX]), declip([IMU0_AccelY]), declip([IMU0_AccelZ])), 0, 1, 0, deg2rad(30)))",
      "quantity": "Acceleration",
      "units": "g",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FFFFC107"
    },
    {
      "name": "Vertical accel",
      "expression": "vz(rotate_axis(vec(declip([IMU0_AccelX]), declip([IMU0_AccelY]), declip([IMU0_AccelZ])), 0, 1, 0, deg2rad(30)))",
      "quantity": "Acceleration",
      "units": "g",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FF8BC34A"
    },
    {
      "name": "Combined horizontal g",
      "expression": "sqrt(pow([Longitudinal accel], 2) + pow([Lateral accel], 2))",
      "quantity": "Acceleration",
      "units": "g",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FFFF9800"
    },
    {
      "name": "Roll rate",
      "expression": "vx(rotate_axis(vec([IMU0_GyroX], [IMU0_GyroY], [IMU0_GyroZ]), 0, 1, 0, deg2rad(30)))",
      "quantity": "Angular Speed",
      "units": "deg/s",
      "sample_rate_hz": 0.0,
      "decimal_places": 1,
      "color": "#FF2196F3"
    },
    {
      "name": "Pitch rate",
      "expression": "vy(rotate_axis(vec([IMU0_GyroX], [IMU0_GyroY], [IMU0_GyroZ]), 0, 1, 0, deg2rad(30)))",
      "quantity": "Angular Speed",
      "units": "deg/s",
      "sample_rate_hz": 0.0,
      "decimal_places": 1,
      "color": "#FF7E57C2"
    },
    {
      "name": "Yaw rate",
      "expression": "vz(rotate_axis(vec([IMU0_GyroX], [IMU0_GyroY], [IMU0_GyroZ]), 0, 1, 0, deg2rad(30)))",
      "quantity": "Angular Speed",
      "units": "deg/s",
      "sample_rate_hz": 0.0,
      "decimal_places": 1,
      "color": "#FFEC407A"
    }
  ],
