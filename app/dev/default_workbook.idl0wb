              "rows": [
                {
                  "id": "r0"
                },
                {
                  "id": "r1"
                },
                {
                  "id": "r2"
                }
              ],
              "cells": [
                [
                  {
                    "literal": 0
                  },
                  {
                    "formula": "median([IMU0_AccelX])"
                  },
                  {
                    "formula": "median([IMU0_AccelY])"
                  },
                  {
                    "formula": "median([IMU0_AccelZ])"
                  },
                  {
                    "formula": "norm(vec(median([IMU0_AccelX]),median([IMU0_AccelY]),median([IMU0_AccelZ])))"
                  }
                ],
                [
                  {
                    "literal": 1
                  },
                  {
                    "formula": "median([IMU1_AccelX])"
                  },
                  {
                    "formula": "median([IMU1_AccelY])"
                  },
                  {},
                  {
                    "formula": "sqrt(median([IMU1_AccelX])*median([IMU1_AccelX]) + median([IMU1_AccelY])*median([IMU1_AccelY]))"
                  }
                ],
                [
                  {
                    "literal": 2
                  },
                  {
                    "formula": "median([IMU2_AccelX])"
                  },
                  {
                    "formula": "median([IMU2_AccelY])"
                  },
                  {},
                  {
                    "formula": "sqrt(median([IMU2_AccelX])*median([IMU2_AccelX]) + median([IMU2_AccelY])*median([IMU2_AccelY]))"
                  }
                ]
              ]
            }
          }
        },
