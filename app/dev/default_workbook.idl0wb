{
  "workbook_id": "default-analysis-v1",
  "name": "Default Analysis",
  "workbook_version": 1,
  "created_at_ms": 1767225600000,
  "updated_at_ms": 1782345600000,
  "math_channels": [
    {
      "name": "Frame accel declipped",
      "expression": "declip([IMU0_AccelZ])",
      "quantity": "Acceleration",
      "units": "g",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FFFFC107"
    },
    {
      "name": "Fork accel declipped",
      "expression": "declip([IMU1_AccelX])",
      "quantity": "Acceleration",
      "units": "g",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FF00BCD4"
    },
    {
      "name": "Shock accel declipped",
      "expression": "declip([IMU2_AccelY])",
      "quantity": "Acceleration",
      "units": "g",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FF8BC34A"
    },
    {
      "name": "Front axle vert accel",
      "expression": "[IMU0_AccelZ] + 0.835 * differentiate([IMU0_GyroY] * 0.0174533) / 9.81",
      "quantity": "Acceleration",
      "units": "g",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FF7E57C2"
    },
    {
      "name": "Rear axle vert accel",
      "expression": "[IMU0_AccelZ] - 0.445 * differentiate([IMU0_GyroY] * 0.0174533) / 9.81",
      "quantity": "Acceleration",
      "units": "g",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FFEC407A"
    },
    {
      "name": "Fork rel accel",
      "expression": "([Fork accel declipped] - [Front axle vert accel]) * g",
      "quantity": "Acceleration",
      "units": "m/s^2",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FF90CAF9"
    },
    {
      "name": "Shock rel accel",
      "expression": "([Shock accel declipped] - [Rear axle vert accel]) * g",
      "quantity": "Acceleration",
      "units": "m/s^2",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FFA5D6A7"
    },
    {
      "name": "Fork vel raw",
      "expression": "integrate(butter(2, 0.2, \"high\", [Fork rel accel]))",
      "quantity": "Velocity",
      "units": "m/s",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#80FF2196F3"
    },
    {
      "name": "Shock vel raw",
      "expression": "integrate(butter(2, 0.2, \"high\", [Shock rel accel]))",
      "quantity": "Velocity",
      "units": "m/s",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#804CAF50"
    },
    {
      "name": "Fork velocity",
      "expression": "detrend([Fork vel raw])",
      "quantity": "Velocity",
      "units": "m/s",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FF2196F3"
    },
    {
      "name": "Shock velocity",
      "expression": "detrend([Shock vel raw])",
      "quantity": "Velocity",
      "units": "m/s",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FF4CAF50"
    },
    {
      "name": "Fork travel",
      "expression": "detrend(integrate([Fork velocity]))",
      "quantity": "Position",
      "units": "m",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FFFF9800"
    },
    {
      "name": "Shock travel",
      "expression": "detrend(integrate([Shock velocity]))",
      "quantity": "Position",
      "units": "m",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FFE91E63"
    },
    {
      "name": "Frame |accel|",
      "expression": "norm(vec([IMU0_AccelX],[IMU0_AccelY],[IMU0_AccelZ]))",
      "quantity": "Acceleration",
      "units": "g",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FFFFFFFF"
    },
    {
      "name": "Cumulative pitch",
      "expression": "integrate([IMU0_GyroY])",
      "quantity": "Angle",
      "units": "deg",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FFFFC107"
    },
    {
      "name": "Pitch ang accel",
      "expression": "differentiate(deg2rad([IMU0_GyroY]))",
      "quantity": "AngularAccel",
      "units": "rad/s^2",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FFBA68C8"
    },
    {
      "name": "Centripetal est",
      "expression": "{r_cent} * deg2rad([IMU0_GyroY]) * deg2rad([IMU0_GyroY])",
      "quantity": "Acceleration",
      "units": "m/s^2",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FFFF7043"
    },
    {
      "name": "Frame vert aligned",
      "expression": "dot(vec([IMU0_AccelX],[IMU0_AccelY],[IMU0_AccelZ]), normalize(vec({g0x},{g0y},{g0z})))",
      "quantity": "Acceleration",
      "units": "g",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FFE0E0E0"
    },
    {
      "name": "Fork |accel|",
      "expression": "norm(vec([IMU1_AccelX],[IMU1_AccelY],0))",
      "quantity": "Acceleration",
      "units": "g",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FF2196F3"
    },
    {
      "name": "Shock |accel|",
      "expression": "norm(vec([IMU2_AccelX],[IMU2_AccelY],0))",
      "quantity": "Acceleration",
      "units": "g",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FF4CAF50"
    },
    {
      "name": "Fork vert aligned",
      "expression": "dot(vec([IMU1_AccelX],[IMU1_AccelY],0), normalize(vec({g1x},{g1y},{g1z})))",
      "quantity": "Acceleration",
      "units": "g",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FF64B5F6"
    },
    {
      "name": "Shock vert aligned",
      "expression": "dot(vec([IMU2_AccelX],[IMU2_AccelY],0), normalize(vec({g2x},{g2y},{g2z})))",
      "quantity": "Acceleration",
      "units": "g",
      "sample_rate_hz": 0.0,
      "decimal_places": 3,
      "color": "#FF81C784"
    },
    {
